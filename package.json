{
  "name": "flutter-getx-template",
  "displayName": "Flutter GetX Page Generator (Controller + Binding + View)",
  "description": "Quickly generate Flutter GetX pages (controller, binding, view) with one click. Boost your Flutter development productivity.",
  "version": "0.1.0",
  "publisher": "zhangjian",
  "icon": "assets/icon.jpg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zyzhangjian/flutter-getx-template"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "flutter",
    "flutter getx",
    "getx",
    "getx generator",
    "flutter generator",
    "flutter code generator",
    "flutter scaffold",
    "flutter page generator",
    "getx scaffold",
    "getx template",
    "flutter boilerplate",
    "flutter productivity"
  ],
  "activationEvents": [
    "onCommand:flutter getx.newGetxTemplate"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flutter getx.newGetxTemplate",
        "title": "Flutter GetX: New GetX Template",
        "category": "Flutter GetX"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "flutter getx.newGetxTemplate",
          "when": "resourceLangId == dart || explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.16.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  }
}
